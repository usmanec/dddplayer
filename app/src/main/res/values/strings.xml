    <string name="pref_skip_silence_off">Play as is</string>
    <string name="pref_audio_boost">Volume Boost</string>
    <string name="pref_audio_boost_desc">Useful for quiet movies. The main goal is to make quiet sounds louder without causing hard clipping (distortion) at peaks.</string>
