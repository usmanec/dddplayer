    <string name="pref_title">Settings</string>
    <string name="pref_title_desc">Global player parameters</string>
    <string name="close_settings">Close settings</string>
    <string name="exit">Exit</string>
    <string name="pref_general_header">Playback</string>
    <string name="pref_decoder_priority">Decoder Priority</string>
    <string name="pref_decoder_priority_prefer_device">Prefer device decoders (default) HW+SW</string>
    <string name="pref_decoder_priority_prefer_app" tools:ignore="Typos">Prefer app decoders (AV1 + Ffmpeg) SW+HW</string>
    <string name="pref_decoder_priority_only_device">Device decoders only</string>
    <string name="pref_decoder_sw_desc">¹ - SW includes AV1 and Ffmpeg decoders (built with audio codecs: vorbis, opus, flac, alac, pcm_mulaw, pcm_alaw, mp3, amrnb, amrwb, aac, ac3, eac3, dca(DTS), mlp, truehd)</string>
    <string name="pref_downmix">Downmix to Stereo</string>
    <string name="pref_downmix_desc">When using the SW decoder, this allows converting multi-channel audio into a properly¹ mixed stereo, which can solve the problem of missing voice/translation (usually present on the center channel).\n¹ - The downmix matrices are calculated similarly to RFC 7845 (Section 5.1.1.5).</string>
    <string name="pref_downmix_config">Downmix Correction</string>
    <string name="pref_downmix_config_desc">You can adjust the volume of audio channels (front, center, rear, side, subwoofer) for the downmix to your liking.</string>
    <string name="pref_downmix_preset">Preset:</string>
    <string name="pref_downmix_front">Front (L/R)</string>
    <string name="pref_downmix_center">Center (Voice)</string>
    <string name="pref_downmix_rear">Rear (Surround)</string>
    <string name="pref_downmix_middle">Side (7.1)</string>
    <string name="pref_downmix_lfe">Subwoofer (LFE)</string>
    <string name="pref_tunneling">Tunneled Playback</string>
    <string name="pref_tunneling_summary">Tunneling allows video to bypass the app and Android framework code, which can provide more efficient rendering of 4K/HDR content, but may not work on all devices.\nWarning!!! With tunneled playback, video processing and synchronization are handled by the end device, so some player features will not work with this option.</string>
    <string name="pref_map_dv">Dolby Vision compatibility</string>
    <string name="pref_map_dv_on">Compatibility mode: play base HDR/HLG layer (HEVC).\nHelps if you get a black screen instead of video (relevant for DV Profile 7).</string>
    <string name="pref_map_dv_off">Full mode: use system DV decoder\n(relevant for devices with native Dolby Vision support).</string>
    <string name="pref_afr_sec">AFR</string>
    <string name="pref_framerate_matching">Auto Frame Rate Matching</string>
    <string name="pref_framerate_matching_on">Switch display refresh rate to match video frame rate</string>
    <string name="pref_framerate_matching_off">Do not change display refresh rate</string>
    <string name="pref_afr_resolution">Switch resolution</string>
    <string name="pref_afr_resolution_desc">Change not only the refresh rate but also the screen resolution</string>
    <string name="pref_afr_fps_correction">Fractional frame rate correction</string>
    <string name="pref_afr_fps_correction_desc">Convert 24/30/60 to 23.976/29.97/59.94</string>
    <string name="pref_afr_double_refresh">Double refresh rate</string>
    <string name="pref_afr_double_refresh_desc">Use a multiple refresh rate for smoother UI (recommended)</string>
    <string name="pref_afr_skip_24">Skip 24Hz</string>
    <string name="pref_afr_skip_24_desc">Do not switch refresh rate if the video is 24fps</string>
    <string name="pref_afr_skip_shorts">Skip short videos</string>
    <string name="pref_afr_skip_shorts_desc">Do not apply AFR to videos shorter than 60 seconds</string>
    <string name="pref_afr_pause">Pause when switching AFR</string>
    <string name="pref_afr_pause_desc">Delay before playback to allow the TV to switch modes</string>
    <string name="afr_pause_format">%.1f sec</string>
    <string name="afr_pause_none">No pause</string>
    <string name="pref_skip_silence">Skip Silence</string>
